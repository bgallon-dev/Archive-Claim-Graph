# Copy this file to `.env` and fill in your local values.
# Never commit the real `.env` file.

# Required for Neo4j backend (`graphrag load-graph --backend neo4j`)
# Local/self-signed example:
NEO4J_URI=bolt+ssc://your-host:7687
# Aura/public CA example:
# NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here

# Optional (defaults to neo4j)
NEO4J_DATABASE=neo4j

# Optional trust settings when using bolt:// or neo4j://
# Values: system | all | custom
NEO4J_TRUST=system
# Required only when NEO4J_TRUST=custom
NEO4J_CA_CERT=

# Optional metadata defaults for extraction runs
OCR_ENGINE=tesseract
OCR_VERSION=5.x

# Optional future LLM settings (adapter-dependent; placeholders only)
LLM_PROVIDER=
LLM_MODEL=
OPENAI_API_KEY=

# Synthesis model (Anthropic). Override to switch models without a code deployment.
# Defaults to claude-sonnet-4-6 if unset.
SYNTHESIS_MODEL=claude-sonnet-4-6

# Required for synthesis (Anthropic Claude API)
# Both names are accepted; ANTHROPIC_API_KEY is the standard form.
ANTHROPIC_API_KEY=sk-ant-...
# Legacy alias (also accepted):
# Anthropic_API_Key=sk-ant-...

# API bearer-token authentication for the query server (graphrag query-serve)
# JSON object mapping token strings to {"role": ..., "institution_id": ...}
# Roles: public | staff | restricted | indigenous_admin | admin
# If unset, server falls back to anonymous public-only access (development mode).
GRAPHRAG_API_TOKENS={"tok_example_staff": {"role": "staff", "institution_id": "turnbull"}, "tok_example_admin": {"role": "admin", "institution_id": "turnbull"}}

# Paths to SQLite log databases (created automatically on first use)
# Conversation query log
CONV_LOG_DB=data/conversation_log.db
# Write-operation audit log (ingestion, soft-deletion, restoration)
WRITE_AUDIT_DB=data/write_audit.db
