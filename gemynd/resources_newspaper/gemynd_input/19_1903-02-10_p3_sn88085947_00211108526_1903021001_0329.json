  "pages": [
    {
      "page_number": 1,
      "raw_text": "There will be meeting of the\nSpokane Real Estate association held\nat the officAs of the Yancey- Williams\ncompany this evening at o'clock.\nThis will be the last of the adjourned\nmeetings and everyone connected with\nthe association is urged to be present.\nTopics that were laid over from the\nlast meeting will be fully discussed.\nHereafter meetings will be held the\nfirst Tuesday of every month."
    }
  ]
